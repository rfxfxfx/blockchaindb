# RPC endpoint of any EVM-compatible network (default: Polygon Amoy testnet)
RPC_URL=https://rpc-amoy.polygon.technology

# Private key of the wallet that owns the Database contract (funds needed for gas)
PRIVATE_KEY=

# Address of the deployed Database.sol contract (fill in after `npm run deploy`)
CONTRACT_ADDRESS=

# Optional API key. When set, external (cross-origin / server-to-server) API
# callers must send it as `x-api-key` (or `Authorization: Bearer`). Leave blank
# for local dev (open). Generate one from the dashboard's API page before
# exposing the app publicly.
API_KEY=
